GEMINI_API_KEY=your_google_ai_studio_key

# Optional overrides
GEMINI_LIVE_MODEL=models/gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Zephyr
HERMES_API_URL=http://127.0.0.1:8642
API_SERVER_KEY=iris-local-dev
# Full path to the hermes binary. Needed because GUI-launched apps often have a
# minimal PATH. Find yours with: which hermes
HERMES_BIN=/Users/you/.local/bin/hermes
VOICE_DUPLEX_MODE=speaker
SPEAKER_ECHO_GUARD_SECONDS=0.9
# Leave unset to auto-use the local .venv. Only set to override the interpreter.
# IRIS_PYTHON=python3
